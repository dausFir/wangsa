# Wangsa App — Backend Environment Variables
# Copy this file to .env and fill in values before running

# Server
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://wangsa:wangsa@localhost:5432/wangsa?sslmode=disable

# JWT — access token TTL (default 15 minutes)
ACCESS_TOKEN_MINUTES=15
# Refresh token is always 30 days (hardcoded in jwt.Manager)

# JWT Secret — WAJIB diubah di production (min 32 karakter acak)
# Generate: openssl rand -hex 32
JWT_SECRET=super-secret-jwt-key-change-in-production-please

# Cookie
COOKIE_DOMAIN=localhost
# Set ke true di production (membutuhkan HTTPS)
PRODUCTION=false

# CORS — URL frontend
FRONTEND_URL=http://localhost:5173
